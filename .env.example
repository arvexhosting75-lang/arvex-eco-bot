# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id
GUILD_ID=your_testing_guild_id

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arvex-bot

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/token

# Features Toggle
FEATURE_ECONOMY=true
FEATURE_QUESTS=true
FEATURE_LEVELING=true
FEATURE_HOSTING=true
FEATURE_MODERATION=true
FEATURE_TICKETS=true

# API & External Services
DASHBOARD_URL=https://dashboard.arvexhosting.com
API_KEY=your_api_key

# Premium Settings
PREMIUM_PRICE=4.99
PREMIUM_GUILD_PRICE=9.99

# Hosting Products
VPS_STOCK=50
MC_SERVER_STOCK=100
WEB_HOSTING_STOCK=200
